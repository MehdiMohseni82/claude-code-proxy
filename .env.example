# Domain name (used by nginx and NextAuth)
DOMAIN=api.example.com

# Admin dashboard credentials (NextAuth login)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Shared secret for Express <-> Next.js service-to-service auth
ADMIN_API_SECRET=generate-a-random-secret-here

# NextAuth JWT signing secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=generate-another-random-secret-here

# Claude Code backend auth (one of):
#   CLAUDE_CODE_OAUTH_TOKEN  -> long-lived OAuth token from `claude setup-token` (uses subscription quota)
#   ANTHROPIC_API_KEY        -> pay-per-token API key from https://console.anthropic.com/settings/keys
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Ollama (local embedding model)
# Default: http://ollama:11434 (Docker service name)
# For local dev without Docker: http://localhost:11434
OLLAMA_URL=http://ollama:11434
